{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@repo/shared": ["./packages/shared/src/index.ts"],
      "@repo/orchestrator": ["./packages/orchestrator/src/index.ts"],
      "@repo/design-systems": ["./packages/design-systems/src/index.ts"],
      "@repo/skills": ["./packages/skills/src/index.ts"],
      "@repo/ui": ["./packages/ui/src/index.ts"],
      "@/lib/utils": ["./packages/ui/src/lib/utils.ts"],
      "@/components/ui/*": ["./packages/ui/src/components/*"],
      "@/hooks/*": ["./packages/ui/src/hooks/*"]
    }
  },
  "exclude": ["tests", "scripts", "node_modules", "dist"]
}
